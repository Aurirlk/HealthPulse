<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.kmbeast.mapper.AiConversationMapper">

    <insert id="save" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO ai_conversation (user_id, title, agent_type, message_count, last_message_time, create_time, update_time)
        VALUES (#{userId}, #{title}, #{agentType}, #{messageCount}, NOW(), NOW(), NOW())
    </insert>

    <update id="update">
        UPDATE ai_conversation
        <set>
            <if test="title != null and title != ''">
                title = #{title},
            </if>
            <if test="messageCount != null">
                message_count = #{messageCount},
            </if>
            <if test="lastMessageTime != null">
                last_message_time = #{lastMessageTime},
            </if>
            update_time = NOW()
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM ai_conversation WHERE id = #{id}
    </delete>

    <delete id="batchDelete" parameterType="list">
        DELETE FROM ai_conversation WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <select id="getById" resultMap="BaseResultMap">
        SELECT * FROM ai_conversation WHERE id = #{id}
    </select>

    <select id="queryByUserId" resultMap="BaseResultMap">
        SELECT *
        FROM ai_conversation
        WHERE user_id = #{userId}
        <if test="agentType != null and agentType != ''">
            AND agent_type = #{agentType}
        </if>
        ORDER BY last_message_time DESC
    </select>

    <select id="countByUserId" resultType="integer">
        SELECT COUNT(*) FROM ai_conversation WHERE user_id = #{userId}
    </select>

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="cn.kmbeast.pojo.entity.AiConversation">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="title" property="title"/>
        <result column="agent_type" property="agentType"/>
        <result column="message_count" property="messageCount"/>
        <result column="last_message_time" property="lastMessageTime"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

</mapper>
